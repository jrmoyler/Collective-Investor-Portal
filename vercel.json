{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/investors/:id", "destination": "/api/investors/[id]" },
    { "source": "/api/investors", "destination": "/api/investors" },
    { "source": "/api/stats", "destination": "/api/stats" },
    { "source": "/api/events", "destination": "/api/events" },
    { "source": "/api/emails", "destination": "/api/emails" },
    { "source": "/api/research", "destination": "/api/research" },
    { "source": "/((?!api|assets).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PATCH, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
